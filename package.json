{
  "name": "classnote-ai",
  "version": "1.0.0",
  "description": "Lecture recording UI prototype",
  "private": true,
  "workspaces": [
    "apps/mobile"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "mobile:start": "npm --workspace apps/mobile run start",
    "mobile:typecheck": "npm --workspace apps/mobile run typecheck",
    "mobile:android": "npm --workspace apps/mobile run android",
    "build:web": "next build",
    "build:standalone": "next build && cp -r public .next/standalone/public 2>/dev/null; cp -r .next/static .next/standalone/.next/static 2>/dev/null",
    "server": "node .next/standalone/server.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "lucide-react": "^1.23.0",
    "next": "^16.2.10",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.10",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3"
  }
}
